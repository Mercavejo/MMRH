+"use client";
+
+import { Box, Stepper, Step, StepLabel, StepIconProps, styled, alpha } from "@mui/material";
+import { 
+  CheckCircle as ValidatedIcon,
+  AltRoute as RoutingIcon,
+  FileUpload as PublishedIcon,
+  Error as ErrorIcon
+} from "@mui/icons-material";
+import type { BatchRoutingProgress } from "@/lib/rh/batches/batch-progress";
+
+const ColorlibStepIconRoot = styled("div")<{
+  ownerState: { active?: boolean; completed?: boolean; error?: boolean };
+}>(({ theme, ownerState }) => ({
+  backgroundColor: alpha(theme.palette.grey[700], 0.1),
+  zIndex: 1,
+  color: "#fff",
+  width: 40,
+  height: 40,
+  display: "flex",
+  borderRadius: "50%",
+  justifyContent: "center",
+  alignItems: "center",
+  ...(ownerState.active && {
+    background: theme.palette.primary.main,
+    boxShadow: `0 0 15px ${alpha(theme.palette.primary.main, 0.4)}`,
+  }),
+  ...(ownerState.completed && {
+    background: theme.palette.success.main,
+  }),
+  ...(ownerState.error && {
+    background: theme.palette.error.main,
+  }),
+}));
+
+function ColorlibStepIcon(props: StepIconProps & { error?: boolean }) {
+  const { active, completed, className, icon, error } = props;
+
+  const icons: { [index: string]: React.ReactElement } = {
+    1: <ValidatedIcon />,
+    2: <RoutingIcon />,
+    3: <PublishedIcon />,
+  };
+
+  return (
+    <ColorlibStepIconRoot ownerState={{ completed, active, error }} className={className}>
+      {error ? <ErrorIcon /> : icons[String(icon)]}
+    </ColorlibStepIconRoot>
+  );
+}
+
+interface BatchStepperProps {
+  summary: BatchRoutingProgress | null;
+  currentStep?: number;
+}
+
+const steps = ["Validacao", "Roteamento", "Publicacao"];
+
+export function BatchStepper({ summary }: BatchStepperProps) {
+  const getActiveStep = () => {
+    if (!summary) return 0;
+    
+    // Step 0: Initial Import/Validation
+    if (summary.routing_status === "pending") return 1; // Validation done, waiting for routing
+    
+    // Step 1: Routing
+    if (summary.routing_status === "completed" || summary.routing_status === "blocked") {
+      if (summary.publication_status === "published") return 3;
+      return 2; // Routing done, waiting for publication
+    }
+    
+    return 0;
+  };
+
+  const activeStep = getActiveStep();
+  const hasError = summary?.routing_status === "failed" || summary?.publication_status === "failed";
+
+  return (
+    <Box sx={{ width: "100%", py: 2 }}>
+      <Stepper activeStep={activeStep} alternativeLabel>
+        {steps.map((label, index) => {
+          const isError = hasError && index === activeStep;
+          return (
+            <Step key={label} completed={index < activeStep}>
+              <StepLabel 
+                StepIconComponent={(props) => <ColorlibStepIcon {...props} error={isError} />}
+                error={isError}
+              >
+                <Typography variant="body2" sx={{ fontWeight: index === activeStep ? 600 : 400 }}>
+                  {label}
+                </Typography>
+              </StepLabel>
+            </Step>
+          );
+        })}
+      </Stepper>
+    </Box>
+  );
+}
+
+// Minimal Typography import fix
+import { Typography } from "@mui/material";
diff --git a/src/components/batches/drop-zone.tsx b/src/components/batches/drop-zone.tsx
new file mode 100644
index 0000000..2a9a597
