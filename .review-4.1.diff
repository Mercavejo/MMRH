+      to: "2026-04-13T23:59:59.999Z",
+      batchId: " bbbbbbbb-bbbb-4bbb-8bbb-bbbbbbbbbbbb ",
+      page: 0,
+      pageSize: 999,
+    });
+
+    expect(normalized.batchId).toBe("bbbbbbbb-bbbb-4bbb-8bbb-bbbbbbbbbbbb");
