+              aria-label={`Prioridade ${getExceptionPriorityLabel(props.item.priority)}`}
+              sx={{ backgroundColor: priorityTone.color, color: tokens.colors.text.inverse }}
+            />
+            <Chip
+              icon={stateTone.icon}
